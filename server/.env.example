# Server
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/ticketpulse
JWT_SECRET=change-this-to-a-random-32-char-string-minimum
JWT_REFRESH_SECRET=change-this-to-another-random-32-char-string
CORS_ORIGIN=http://localhost:5173

# Clover (sandbox mode — no credentials needed)
CLOVER_SANDBOX=true
CLOVER_MERCHANT_ID=
CLOVER_API_TOKEN=
CLOVER_BASE_URL=https://sandbox.dev.clover.com

# SendGrid (optional — emails logged to console when not set)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=tickets@ticketpulse.app
SENDGRID_FROM_NAME=TicketPulse
