# Server
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/ticketpulse
JWT_SECRET=your-jwt-secret-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-this
CORS_ORIGIN=http://localhost:5173

# Clover
CLOVER_SANDBOX=true
CLOVER_MERCHANT_ID=
CLOVER_API_TOKEN=
CLOVER_BASE_URL=https://sandbox.dev.clover.com

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=tickets@ticketpulse.app
SENDGRID_FROM_NAME=TicketPulse

# Supabase (optional — only if using Supabase client directly)
SUPABASE_URL=
SUPABASE_ANON_KEY=
